# MongoDB Connection String (Required)
MONGO_URI=mongodb+srv://Dubai:ab1ab2ab3@cluster0.mgmzmip.mongodb.net/reatEstate

# Server Port (optional, default 4001)
PORT=4001

# JWT Secrets (Required - generate strong secrets)
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ACCESS_SECRET=your-access-token-secret-change-this
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this

# JWT Token Expiry
JWT_ACCESS_SECRET_EXPIRY=15m
JWT_REFRESH_SECRET_EXPIRY=7d

# Frontend URL (included in default CORS allowlist when ALLOWED_ORIGINS is unset)
FRONTEND_URL=http://localhost:3000

# Cloudinary (required for property images and PDF brochures)
# Security → enable “Allow delivery of PDF and ZIP files” if direct PDF links return 401
# On Vercel: Project → Settings → Environment Variables → add all three → Redeploy
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google OAuth - Optional
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Default Admin Credentials
ADMIN_NAME=System Administrator
ADMIN_EMAIL=admin@awr-properties.com
ADMIN_PASSWORD=Admin123!

# Allowed Origins (comma-separated for CORS)
ALLOWED_ORIGINS=https://appraisalsassets-client-delta.vercel.app,http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,https://www.assetsappraisals.com,https://assetsappraisals.com

# --- Vercel production (appraisalsassets-server) ---
# Project → Settings → Environment Variables → Production → Redeploy after saving
# Required: MONGO_URI, JWT_ACCESS_SECRET, JWT_REFRESH_SECRET, ADMIN_EMAIL, ADMIN_PASSWORD
# Recommended: NODE_ENV=production, ALLOWED_ORIGINS (your live client URL), FRONTEND_URL
# MongoDB Atlas: Network Access → allow 0.0.0.0/0 (or Vercel IPs) so serverless can connect
# Verify after deploy: GET https://appraisalsassets-server.vercel.app/api/health